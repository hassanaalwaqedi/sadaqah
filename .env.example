# ============================================================
# Sadaqah Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file to version control.
# ============================================================

# ---------- General ----------
APP_ENV=development
APP_NAME=sadaqah

# ---------- Go API ----------
API_HOST=0.0.0.0
API_PORT=8080
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=15s
API_IDLE_TIMEOUT=60s

# ---------- JWT ----------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ---------- PostgreSQL ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=sadaqah
DB_PASSWORD=sadaqah_dev_password
DB_NAME=sadaqah
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- MinIO / S3 ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sadaqah-files
MINIO_USE_SSL=false

# ---------- FastAPI AI Worker ----------
AI_WORKER_HOST=ai-worker
AI_WORKER_PORT=8000
AI_INTERNAL_API_KEY=change-me-internal-api-key

# ---------- Email (SMTP) ----------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sadaqah.org

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Nginx ----------
NGINX_PORT=80
NGINX_SSL_PORT=443
